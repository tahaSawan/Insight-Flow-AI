# Copy to .env and add your key from https://aistudio.google.com/apikey
EXPO_PUBLIC_GEMINI_API_KEY=your_api_key_here

# Optional — defaults to gemini-2.0-flash-lite (best for free-tier keys)
# EXPO_PUBLIC_GEMINI_MODEL=gemini-2.0-flash-lite

# After changing .env, restart Expo and clear cache:
#   npx expo start -c
